# ─────────────────────────────────────────────────────────────────────────────
# Stewart Title Fraud Detection — Environment Configuration
# Copy this file to config/settings.env and fill in your values.
# NEVER commit settings.env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure AI Foundry ──────────────────────────────────────────────────────────
# From: ai.azure.com → your project → Overview → Project endpoint
FOUNDRY_PROJECT_ENDPOINT=https://your-hub.services.ai.azure.com/api/projects/stewart-title-fraud-detection

# GPT-4o deployment name (created in Phase 1.2)
FOUNDRY_MODEL_DEPLOYMENT=gpt-4o-fraud

# Azure region of your Foundry hub
AZURE_REGION=eastus2

# ── Microsoft Fabric ──────────────────────────────────────────────────────────
# From: app.fabric.microsoft.com URL when viewing the workspace
FABRIC_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# From: URL when viewing the Lakehouse item
FABRIC_LAKEHOUSE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
FABRIC_LAKEHOUSE_NAME=stewart_title_claims

# From: URL when viewing the Data Agent item (after Phase 4 setup)
FABRIC_AGENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Authentication ────────────────────────────────────────────────────────────
# When running INSIDE Fabric notebooks: leave these blank.
# Managed Identity is used automatically.
#
# When running LOCALLY (scripts/, local testing):
# Option A: az login (recommended — just run `az login` before scripts)
# Option B: Service principal (fill in below)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Fraud Scoring Thresholds (tunable) ────────────────────────────────────────
FRAUD_HIGH_THRESHOLD=0.75
FRAUD_MEDIUM_THRESHOLD=0.45
FRAUD_ALERT_AMOUNT_MIN=50000    # Only trigger Foundry for claims above this amount

# ── Foundry Agent IDs (populated by provision_foundry.py) ────────────────────
# These are written automatically — do not edit manually
AGENT_ID_ORCHESTRATOR=
AGENT_ID_IDENTITY=
AGENT_ID_PROPERTY=
AGENT_ID_CLAIMS_PATTERN=
AGENT_ID_COMPLIANCE=
